# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (comma-separated)
CORS_ORIGINS=chrome-extension://*,http://localhost:3000,http://localhost:3001

# Database Configuration
DATABASE_URL=file:./ngips.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=text

# ML Model Configuration
MODEL_DIR=./models
LOGISTIC_REGRESSION_MODEL_PATH=../phishingApp.pkl
NAIVE_BAYES_MODEL_PATH=../phishingApp Updated.pkl
MODEL_VERSION=1.0.0

# Rate Limiting Configuration
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_ENABLED=true

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Security Configuration
SECRET_KEY=change-me-in-production

# Threat Intelligence Configuration
THREAT_INTEL_ENABLED=false
PHISHTANK_API_KEY=
THREAT_DB_UPDATE_INTERVAL_HOURS=24

# Performance Configuration
API_TIMEOUT_SECONDS=5
