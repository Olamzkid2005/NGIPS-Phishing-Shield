{
  "manifest_version": 3,
  "name": "NGIPS Phishing Shield",
  "version": "1.0.0",
  "description": "Real-time phishing protection for your browser",
  "permissions": ["webNavigation", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg"
    }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/content-script.js"],
    "css": ["content/overlay.css"]
  }],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg"
  }
}